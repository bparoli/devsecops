# Secret template for the diagnostic and remediation agents.
#
# Usage:
#   cp k8s/monitoring/agent-secret.yaml.template k8s/monitoring/agent-secret.yaml
#   # Fill in your values in agent-secret.yaml, then:
#   kubectl apply -f k8s/monitoring/agent-secret.yaml
#
# agent-secret.yaml is gitignored — never commit it with real credentials.
#
# How to obtain each value:
#   TELEGRAM_TOKEN:   Create a bot via @BotFather on Telegram
#   TELEGRAM_CHAT_ID: Send a message to your bot, then run:
#                     curl https://api.telegram.org/bot<TOKEN>/getUpdates
#   ANTHROPIC_API_KEY: https://console.anthropic.com/settings/keys
#   JIRA_URL:         Your Jira base URL, e.g. https://yourorg.atlassian.net
#   JIRA_EMAIL:       Your Atlassian account email
#   JIRA_API_TOKEN:   https://id.atlassian.com/manage-profile/security/api-tokens
#   JIRA_PROJECT_KEY: Project key where issues will be created (e.g. OPS, INFRA)
#   GITHUB_TOKEN:     GitHub PAT with repo scope — github.com/settings/tokens
#   GITHUB_REPO:      Repository in owner/repo format (e.g. myorg/myrepo)
#
apiVersion: v1
kind: Secret
metadata:
  name: agent-secrets
  namespace: monitoring
type: Opaque
stringData:
  TELEGRAM_TOKEN: "<your-telegram-bot-token>"
  TELEGRAM_CHAT_ID: "<your-telegram-chat-id>"
  ANTHROPIC_API_KEY: "<your-anthropic-api-key>"
  JIRA_URL: "<https://yourorg.atlassian.net>"
  JIRA_EMAIL: "<your-atlassian-email>"
  JIRA_API_TOKEN: "<your-jira-api-token>"
  JIRA_PROJECT_KEY: "<your-project-key>"
  GITHUB_TOKEN: "<your-github-pat>"
  GITHUB_REPO: "<owner/repo>"
